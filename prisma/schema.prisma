// Lumina — personal media streaming frontend
// Prisma schema (SQLite)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

/// A movie or a TV show (top-level item)
model Media {
  id               String          @id @default(cuid())
  type             String // "MOVIE" | "TV"
  title            String
  sortTitle        String?
  /// Movie: path to the video file. TV: path to the show root folder.
  filePath         String?
  /// Filesystem timestamps for the source file/folder, used for Plex-like recently-added shelves.
  sourceCreatedAt  DateTime?
  sourceModifiedAt DateTime?
  /// Optional remote URL used when no local file is available (demo / fallback)
  streamUrl        String?
  tmdbId           Int?            @unique
  imdbId           String?
  overview         String?
  tagline          String?
  /// Full URL to poster image
  posterUrl        String?
  /// Full URL to backdrop image
  backdropUrl      String?
  releaseDate      DateTime?
  year             Int?
  /// Runtime in minutes (movie runtime or average episode runtime)
  runtime          Int?
  /// 0–10 rating (TMDB vote average)
  rating           Float?
  voteCount        Int?
  status           String?
  certification    String?
  featured         Boolean         @default(false)
  trending         Boolean         @default(false)
  popularity       Float           @default(0)
  /// Which library section this belongs to (denormalised category for fast unified queries)
  sectionId        String?
  section          LibrarySection? @relation(fields: [sectionId], references: [id], onDelete: SetNull)
  /// "default" | "anime" | custom — denormalised from section so home/browse stay unified by type
  category         String          @default("default")
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  genres      MediaGenre[]
  episodes    Episode[]
  progress    WatchProgress[]
  collections CollectionItem[]
  subtitles   Subtitle[]

  @@index([type])
  @@index([year])
  @@index([featured])
  @@index([trending])
  @@index([sectionId])
  @@index([category])
  @@index([sourceModifiedAt])
}

model Episode {
  id               String          @id @default(cuid())
  mediaId          String
  media            Media           @relation(fields: [mediaId], references: [id], onDelete: Cascade)
  seasonNumber     Int
  episodeNumber    Int
  title            String
  filePath         String?
  sourceCreatedAt  DateTime?
  sourceModifiedAt DateTime?
  streamUrl        String?
  overview         String?
  stillUrl         String?
  airDate          DateTime?
  runtime          Int?
  createdAt        DateTime        @default(now())
  progress         WatchProgress[]
  subtitles        Subtitle[]

  @@unique([mediaId, seasonNumber, episodeNumber])
  @@index([mediaId, seasonNumber])
  @@index([sourceModifiedAt])
}

model Genre {
  id    Int          @id
  name  String       @unique
  media MediaGenre[]
}

model MediaGenre {
  mediaId String
  genreId Int
  media   Media  @relation(fields: [mediaId], references: [id], onDelete: Cascade)
  genre   Genre  @relation(fields: [genreId], references: [id])

  @@id([mediaId, genreId])
}

/// Per-user watch progress (single user assumed for personal library)
model WatchProgress {
  id        String   @id @default(cuid())
  mediaId   String
  episodeId String?
  media     Media    @relation(fields: [mediaId], references: [id], onDelete: Cascade)
  episode   Episode? @relation(fields: [episodeId], references: [id], onDelete: Cascade)
  position  Float    @default(0) // seconds played
  duration  Float    @default(0) // seconds total
  completed Boolean  @default(false)
  updatedAt DateTime @updatedAt

  @@index([mediaId, episodeId])
}

/// A user-curated list (e.g. "My List")
model Collection {
  id        String           @id @default(cuid())
  name      String
  slug      String           @unique @default("my-list")
  createdAt DateTime         @default(now())
  items     CollectionItem[]
}

model CollectionItem {
  id           String     @id @default(cuid())
  collectionId String
  mediaId      String
  addedAt      DateTime   @default(now())
  collection   Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  media        Media      @relation(fields: [mediaId], references: [id], onDelete: Cascade)

  @@unique([collectionId, mediaId])
}

/// A library scan section — each has its own media directory + type + category.
/// e.g. "TV Shows" (type=TV, category=default), "TV Shows (Anime)" (type=TV, category=anime),
///      "Movies" (type=MOVIE, category=default), "Movies (Anime)" (type=MOVIE, category=anime)
/// Display (home/browse) is always unified by `type`; sections are only for scanning + mounting.
model LibrarySection {
  id        String    @id @default(cuid())
  name      String    @unique
  /// "MOVIE" | "TV"
  type      String
  /// "default" | "anime" | custom label used to group but NOT to split display
  category  String    @default("default")
  mediaDir  String
  tmdbKey   String?
  autoMatch Boolean   @default(true)
  lastScan  DateTime?
  scanCount Int       @default(0)
  createdAt DateTime  @default(now())
  media     Media[]

  @@index([type])
  @@index([category])
}

/// A subtitle track for a movie or episode.
/// Served as WebVTT (SRT is auto-converted by the /api/subtitles/:id endpoint).
model Subtitle {
  id        String   @id @default(cuid())
  mediaId   String
  episodeId String?
  media     Media    @relation(fields: [mediaId], references: [id], onDelete: Cascade)
  episode   Episode? @relation(fields: [episodeId], references: [id], onDelete: Cascade)
  /// ISO 639-1 language code, e.g. "en", "ja", "es"
  language  String   @default("en")
  /// Human label, e.g. "English", "Japanese (with subs)"
  label     String
  /// Local path to subtitle file (.srt, .vtt, .ass, .ssa, .sub)
  filePath  String?
  /// Direct URL (used for demo / remote subs)
  streamUrl String?
  /// Format hint derived from extension: "vtt" | "srt" | "ass" | "ssa" | "sub"
  format    String   @default("srt")
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([mediaId])
  @@index([episodeId])
}

/// Global library configuration (TMDB key default, etc.)
model LibraryConfig {
  id                String    @id @default("default")
  mediaDir          String    @default("/media")
  tmdbKey           String?
  plexUrl           String?
  plexToken         String?
  plexSyncDirection String    @default("pull")
  lastScan          DateTime?
  scanCount         Int       @default(0)
}
